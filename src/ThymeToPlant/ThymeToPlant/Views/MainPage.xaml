<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ThymeToPlant.Views.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="30,0"
            VerticalOptions="Center">

            <Label
                Text="Hello, Planters!!"
                SemanticProperties.HeadingLevel="Level1"
                FontSize="32"
                HorizontalOptions="Center" />

            <Frame
                BorderColor="#4CAF50"
                BackgroundColor="#F2FFF2"
                CornerRadius="12"
                Padding="16"
                HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="USDA Zone Details"
                        SemanticProperties.HeadingLevel="Level2"
                        FontSize="20"
                        FontAttributes="Bold" />
                    <Label
                        Text="{Binding ZoneCode, StringFormat='Zone: {0}'}" />
                    <Label
                        Text="{Binding ZoneTemperatureRange, StringFormat='Temperature Range: {0}'}" />
                    <Label
                        Text="{Binding ZoneSearchedAt, StringFormat='Last Updated: {0}'}" />
                    <Label
                        Text="{Binding ZoneDescription, StringFormat='Description: {0}'}"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>

            <HorizontalStackLayout
                HorizontalOptions="Center"
                Spacing="8">
                <Entry
                    Placeholder="enter zipcode"
                    WidthRequest="160"
                    Text="{Binding ZipCode}" />
                <Button
                    Text="Use my location"
                    Command="{Binding UseMyLocationCommand}" />
            </HorizontalStackLayout>

            <Button
                Text="Find PlantZone"
                HorizontalOptions="Center"
                Command="{Binding FindPlantZoneCommand}" />

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                HorizontalOptions="Center" />

            <Label
                HorizontalOptions="Center"
                FontSize="14"
                Text="{Binding LocationStatusMessage}"
                TextColor="DarkRed" />

            <Label
                HorizontalOptions="Center"
                FontSize="18"
                Text="{Binding ErrorMessage}"
                IsVisible="{Binding HasError}"
                TextColor="Red" />

            <!--<Button
                x:Name="AIPlantingZone"
                Text="Ask AI Planting Zones"
                HorizontalOptions="Center" />

            <Button
                x:Name="AICompanionPlants"
                Text="Ask AI Companion Plants"
                HorizontalOptions="Center" />-->

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
